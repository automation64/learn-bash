#!/usr/bin/env bash
#
# Development environment variables
#
# * Used by DevBin64 to define project wide variables
# * Automatically loaded by dev-set
# * Do not include local variables (workstation specific) and secrets. Use .local.env and .secrets.env instead
# * Version: 1.0.0
# * Template: 5.0.0
#

#
# DevBin64 variables
#
# * Use to customize devbin64 module variables
# * Module variables are defined in bin/dev-env-MODULE
#

# Env / GIT / Upstream URL
export DEV_GIT_REMOTE_UPSTREAM_URL='https://github.com/automation64/iac64-bash-reference.git'

# Deploy / IaC64 / Enable guardrail to prevent unintended deployment
export DEV_DEPLOY_IAC64_GUARDRAIL_ENABLED='NO'

# Remove / IaC64 / Enable guardrail to prevent unintended removal
export DEV_REMOVE_IAC64_GUARDRAIL_ENABLED='NO'

#
# Project variables
#

# Warning: predefined profile for testing.
DEV_PROFILE='snd'
